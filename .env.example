# Copy to .env.dev / .env.prod and fill in real values. Real env files are gitignored.
# Consumed by `just render <env>`.

# --- Target network / canister selection ---
DFX_NETWORK=test

# --- Workload domain + app config ---
OFFCHAIN_SERVICE_DOMAIN=offchain.example.com
FRONTEND_URL=https://console.example.com
PORT=3000
PRIVATE_KEY=replace-me

# --- TLS (Caddy Cloudflare DNS challenge) ---
CLOUDFLARE_API_TOKEN=replace-me

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-me
SMTP_PASS=replace-me
SMTP_FROM=no-reply@example.com

# --- Grafana Alloy / Cloud ---
GRAFANA_ENVIRONMENT=dev
GRAFANA_SCRAPE_INTERVAL=60s
GRAFANA_HOSTED_OTLP_URL=https://otlp.example.com
GRAFANA_HOSTED_OTLP_ID=000000
GRAFANA_HOSTED_METRICS_URL=https://metrics.example.com
GRAFANA_HOSTED_METRICS_ID=000000
GRAFANA_HOSTED_LOGS_URL=https://logs.example.com
GRAFANA_HOSTED_LOGS_ID=000000
GRAFANA_RW_API_KEY=replace-me

# --- Outline (scripts/outline.ts query CLI; not consumed by just render) ---
# Token from Outline Settings -> API Keys; scope to: documents.* + collections.*
OUTLINE_URL=https://subnet.getoutline.com
OUTLINE_API_TOKEN=replace-me

# Baked into the rendered remote paths by `just render`. Host connection itself is owned by ssn-infra's ansible.
REMOTE_USER=rockylinux
