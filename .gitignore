# Mac OSX temporary files
.DS_Store
**/.DS_Store

# dfx temporary files
.dfx

# icp-cli: cache is disposable; .icp/data (canister id mappings) is committed
.icp/cache

# build output
target
node_modules
dist
.turbo
tsconfig.tsbuildinfo

# environment variables
.env*
!.env.example
# Committed: ships the public RFC 8032 test-vector keys + local defaults. Safe
# to track precisely because it contains no real secrets. `cp` it to .env.local.
!.env.local.example

# local dev keys
.local

# backgrounded local service pids + logs (just local-up)
local/run

# local mirror of the Outline "Process & Use-Case Library" collection (scripts/outline.ts export) - never publish
docs/process-library

# deployment temporary files
tmp

# canbench local runtime files
**/.canbench
# flamegraphs from `canbench --instruction-tracing` and `--csv` results land next to results.yml
benchmarks/**/*.svg
benchmarks/**/canbench_results.csv
