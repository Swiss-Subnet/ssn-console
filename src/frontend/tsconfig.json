{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "@/*": ["./src/*"]
