default:
    @just --list

# Format every service module (gofumpt + goimports via golangci-lint)
fmt:
    golangci-lint fmt

# Verify formatting + vet across every service module
check:
    #!/usr/bin/env bash
    set -euo pipefail
    golangci-lint fmt --diff
    for svc in */; do
        [ -f "${svc}go.mod" ] || continue
        (cd "$svc" && go vet ./...)
    done

# Run golangci-lint across every service module
lint:
    #!/usr/bin/env bash
    set -euo pipefail
    for svc in */; do
        [ -f "${svc}go.mod" ] || continue
        (cd "$svc" && golangci-lint run ./...)
    done

# Run tests across every service module; args forwarded to `go test`
test *args:
    #!/usr/bin/env bash
    set -euo pipefail
    for svc in */; do
        [ -f "${svc}go.mod" ] || continue
        (cd "$svc" && go test ./... {{args}})
    done

# Build every service into services/<name>/bin/<name>
build:
    #!/usr/bin/env bash
    set -euo pipefail
    for svc in */; do
        name="${svc%/}"
        [ -f "$name/go.mod" ] || continue
        echo "building $name"
        (cd "$name" && go build -o "bin/$name" "./cmd/$name")
    done

# Run a service locally with env loaded from ../.env.local
# Usage: just services::run auth-service
run svc:
    #!/usr/bin/env bash
    set -euo pipefail
    cd ..
    set -a; . .env.local; set +a
    cd services/{{svc}}
    go run ./cmd/{{svc}}

# Run metrics-proxy locally. Loads ../.env.local then derives the
# backend canister id from .dfx/local/canister_ids.json so the recipe
# works as soon as `dfx deploy backend` has run. PORT is forced to 3001
# to dodge auth-service's PORT=3000. Without GRAFANA_URL the proxy
# falls back to the in-memory fake data source. The proxy authenticates
# as the RFC 8032 test-vector identity by default (loopback only); set
# PROXY_IDENTITY_PEM to override.
# Usage: just services::metrics-proxy
metrics-proxy:
    #!/usr/bin/env bash
    set -euo pipefail
    cd ..
    set -a; . .env.local; set +a
    if [ -z "${BACKEND_CANISTER_ID:-}" ]; then
        if [ -f .dfx/local/canister_ids.json ]; then
            export BACKEND_CANISTER_ID=$(jq -r '.backend.local' .dfx/local/canister_ids.json)
        fi
    fi
    if [ -z "${IC_HOST:-}" ]; then
        # Prefer pocket-ic (8000) over dfx start (4943); both reachable locally.
        if curl -s -m 1 -o /dev/null http://127.0.0.1:8000/api/v2/status; then
            export IC_HOST=http://127.0.0.1:8000
        else
            export IC_HOST=http://127.0.0.1:4943
        fi
    fi
    cd services/metrics-proxy
    export PORT=3001
    go run ./cmd/metrics-proxy
