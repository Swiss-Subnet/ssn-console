# Local-dev env. `cp .env.local.example .env.local` then `just local-up`.
# Committed because it holds NO real secrets: the keypair below is the public
# RFC 8032 Test 1 vector, usable only against the local replica. Never put a
# real key here -- this file is tracked.

# RFC 8032 Test 1 keypair. PRIVATE_KEY signs as the principal whose PUBLIC_KEY
# set-canister-env.sh installs on the backend + cycles-monitor canisters; they
# must match or record_usage / token verification fails on the IC side.
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEIJ1hsZ3v/VpguoRK9JLsLMREScVpezJpGXA7rAMcrn9g
-----END PRIVATE KEY-----"
PUBLIC_KEY="MCowBQYDK2VwAyEA11qYAYKxCrfVS/7TyWQHOg7hcvPapiMlrwIaaPcHURo="

FRONTEND_URL=http://localhost:4200
PORT=3000

# SMTP -> Mailpit (`docker run --rm -p 1025:1025 -p 8025:8025 axllent/mailpit`).
# Blank user/pass: Mailpit implements no AUTH.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Swiss Subnet <noreply@local>"

GRAFANA_ENVIRONMENT=local
