{
	# Uncomment for staging while testing/debugging
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	admin :2019 {
		origins 0.0.0.0
	}

	servers {
		metrics
	}

	log default {
		output stdout
		format json
	}
}

${AUTH_SERVICE_DOMAIN}:443 {
	# One API host, services split by subpath. metrics-proxy (/v1/*) is not
	# deployed yet; its matcher is reserved here and goes live with that service.
	@auth path /v1.0/auth/* /status
	reverse_proxy @auth ${AUTH_SERVICE_IMAGE_NAME}:${PORT} {
		header_up X-Real-IP {remote_host}
	}

	tls {
		dns cloudflare ${CLOUDFLARE_API_TOKEN}
	}

	log
}
