{
	# Uncomment for staging while testing/debugging
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	admin :2019 {
		origins 0.0.0.0
	}

	servers {
		metrics
	}

	log default {
		output stdout
		format json
	}
}

${AUTH_SERVICE_DOMAIN}:443 {
	# One API host, services split by subpath. All routes are versioned /v0/*
	# (beta; unstable contract); each service owns one explicit prefix so an
	# unknown /v0/* 404s instead of being swallowed. Each prefix includes the
	# service's own /status health endpoint (e.g. /v0/auth/status).
	handle /v0/auth/* {
		reverse_proxy ${AUTH_SERVICE_IMAGE_NAME}:${PORT} {
			header_up X-Real-IP {remote_host}
		}
	}

	handle /v0/payrexx/* {
		reverse_proxy ${PAYMENTS_SERVICE_SERVICE_NAME}:3001 {
			header_up X-Real-IP {remote_host}
		}
	}

	handle /v0/metrics/* {
		reverse_proxy ${METRICS_PROXY_SERVICE_NAME}:3001 {
			header_up X-Real-IP {remote_host}
		}
	}

	tls {
		dns cloudflare ${CLOUDFLARE_API_TOKEN}
	}

	log
}
