{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["dfx.json", "tsconfig.json"],
  "globalEnv": [
    "DFX_VERSION",
    "DFX_NETWORK",
    "CANISTER_ID_INTERNET_IDENTITY",
    "CANISTER_ID_CYCLES_MONITOR",
    "CANISTER_ID_BACKEND",
    "CANISTER_ID_CANISTER_HISTORY",
    "PRIVATE_KEY",
    "FRONTEND_URL",
    "OFFCHAIN_SERVICE_DOMAIN",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_FROM",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
